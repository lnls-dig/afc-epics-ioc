record(aai,"$(P)$(R)$(ACQ_NAME)PosXData") {
    field(EGU, "nm")
    field(NELM, "$(NELM)")
    field(FTVL, "DOUBLE")
    info(Q:group, {
        "$(P)$(R)$(ACQ_NAME)Data-Mon": {
            "value.X": {+type: "plain", +channel: "VAL"}
        }
    })
}

